{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build DrawFeyn Showcase",
      "type": "shell",
      "command": "typst",
      "args": [
        "compile",
        "--root",
        ".",
        "examples/showcase.typ",
        "examples/showcase.pdf"
      ],
      "options": {
        "cwd": "${workspaceFolder}/DrawFeyn"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
